{
  "name": "claude-terminal",
  "productName": "ClaudeTerminal",
  "version": "1.7.2",
  "description": "A Windows Terminal-like app for managing multiple Claude Code instances in tabs",
  "main": ".vite/build/index.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "pnpm run build:web && electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "watch": "electron-forge start",
    "build:web": "vite build --config vite.web.config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "dotenv -- release-it",
    "release:minor": "dotenv -- release-it minor",
    "release:major": "dotenv -- release-it major"
  },
  "keywords": [
    "electron",
    "terminal",
    "claude",
    "claude-code",
    "ai",
    "developer-tools",
    "xterm",
    "git-worktree",
    "tabs",
    "session-management"
  ],
  "author": {
    "name": "Yaron Guan Golan",
    "email": "yg@lifemapsc.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@release-it/conventional-changelog": "^10.0.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cross-spawn": "^6.0.6",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dotenv-cli": "^11.0.0",
    "electron": "40.6.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "release-it": "^19.2.4",
    "typescript": "~5.7.0",
    "vite": "^5.4.21",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@lucide/lab": "^0.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.2.1",
    "bufferutil": "^4.1.0",
    "class-variance-authority": "^0.7.1",
    "cloudflared": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-spawn": "^7.0.6",
    "electron-squirrel-startup": "^1.0.1",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tree-kill": "^1.2.2",
    "tw-animate-css": "^1.4.0",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.19.0"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "node-pty"
    ]
  }
}
